site/

# Python
__pycache__/
*.pyc
.venv/
venv/
.ruff_cache/
.pytest_cache/

# Node
node_modules/

# OS
.DS_Store

# Claude Code (user-specific, not shared config)
settings.local.json
CLAUDE.local.md

# Git worktrees (project-local, isolated feature workspaces)
.worktrees/

# Claude Code local clone (derived from root via scripts/deploy-harness.sh)
.claude/

# Timestamped harness backups (created by deploy/install scripts; not tracked)
.harness-backup-*/

# Local-only research notes (kept out of the tracked tree by request)
docs/memory/
# Added by code-review-graph
.code-review-graph/

# Specifications — tracked, EXCEPT derived artifacts rebuildable from PLAN.md via render_plan.py
specs/**/PLAN.html
specs/**/.plan-review.json
# Derived, machine-local review receipt (written after review passes; not shipped)
specs/**/.review-receipt.json

.vercel

# Local-only harness-engineering review docs
docs/harness-engineering-review.md
docs/harness-engineering-review.en.md

# bootstrap-xia2 review artifacts — per-repo, never shipped by the harness
*.proposed

# generated PR description (finishing-a-development-branch Step 3), not committed
.pr-body.md
